<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="720.0" prefWidth="1080.0" style="-fx-background-color: #F8FAFC;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a77.controllers.MainController" styleClass="app-root">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" styleClass="page-content">
            <padding>
                <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label text="Aperçu Admin : Articles" textFill="#1e293b" styleClass="page-title">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                        <Button onAction="#ajouterArticle" styleClass="primary-button" text="+ Nouvel Article" />
                    </children>
                </HBox>

                <TableView fx:id="tableArticles" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colIdArt" prefWidth="50.0" text="ID" />
                        <TableColumn fx:id="colTitreArt" prefWidth="250.0" text="Titre" />
                        <TableColumn fx:id="colAuteurArt" prefWidth="150.0" text="Auteur" />
                        <TableColumn fx:id="colViewsArt" prefWidth="100.0" text="Vues" />
                        <TableColumn fx:id="colStatutArt" prefWidth="120.0" text="Statut" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>