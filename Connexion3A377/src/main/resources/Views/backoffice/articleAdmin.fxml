<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="800.0" prefWidth="1100.0"
            style="-fx-background-color: #f8fafc;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.connexion3a77.controllers.ArticleController.articleAdmin">

    <VBox AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">

        <!-- TOP NAVBAR -->
        <VBox styleClass="admin-topbar">
            <padding><Insets top="20" right="30" bottom="12" left="30"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Button text="&#8592; Retour aux Magazines" styleClass="back-button"
                        onAction="#retourMagazines"
                        style="-fx-background-color: rgba(255,255,255,0.12); -fx-text-fill: white;
                               -fx-border-color: rgba(255,255,255,0.25); -fx-border-radius: 20;
                               -fx-background-radius: 20; -fx-padding: 7 16; -fx-cursor: hand;"/>
                <Label text="Admin — Gestion des Articles" styleClass="admin-topbar-title"/>
            </HBox>
            <Label fx:id="lblArticleCount" text="0 article(s)"
                   style="-fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-padding: 6 0 0 0;"/>
        </VBox>

        <!-- TOOLBAR : recherche + filtre + tri + bouton ajout -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: white; -fx-padding: 14 28;
                     -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
            <TextField fx:id="tfSearch" promptText="🔍 Rechercher..."
                       styleClass="search-field" prefWidth="260"
                       onKeyReleased="#onSearchChanged"/>
            <ComboBox fx:id="cbFiltrePublic" promptText="Public cible"
                      prefWidth="150" onAction="#onFiltreChanged"/>
            <ComboBox fx:id="cbTri" prefWidth="180" onAction="#onTriChanged"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="+ Nouvel Article" styleClass="admin-add-btn"
                    onAction="#ouvrirFormulaireAjout"/>
        </HBox>

        <!-- TABLE -->
        <VBox VBox.vgrow="ALWAYS" style="-fx-padding: 20 28 0 28;">
            <VBox styleClass="admin-table-card" VBox.vgrow="ALWAYS">
                <TableView fx:id="tableArticles" styleClass="admin-table"
                           VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId"      text="ID"          prefWidth="50"/>
                        <TableColumn fx:id="colTitre"   text="Titre"       prefWidth="220"/>
                        <TableColumn fx:id="colAuteur"  text="Auteur"      prefWidth="130"/>
                        <TableColumn fx:id="colPublic"  text="Public"      prefWidth="100"/>
                        <TableColumn fx:id="colViews"   text="Vues"        prefWidth="70"/>
                        <TableColumn fx:id="colStatut"  text="Statut"      prefWidth="100"/>
                        <TableColumn fx:id="colDatePub" text="Date"        prefWidth="120"/>
                        <TableColumn fx:id="colActions" text="Actions"     prefWidth="160"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>

        <!-- PAGINATION -->
        <HBox alignment="CENTER" spacing="14" style="-fx-padding: 14 0 20 0;">
            <Button fx:id="btnPrev" text="← Précédent" styleClass="secondary-button"
                    onAction="#pagePrecedente"/>
            <Label fx:id="lblPage" text="Page 1 / 1"
                   style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
            <Button fx:id="btnNext" text="Suivant →" styleClass="secondary-button"
                    onAction="#pageSuivante"/>
        </HBox>
    </VBox>
</AnchorPane>
