<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="720.0" prefWidth="1080.0" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a77.controllers.MainController">
    <children>
        <VBox AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0">
            <children>
                <!-- TOP NAVBAR -->
                <VBox styleClass="admin-topbar">
                    <padding><Insets top="20.0" right="30.0" bottom="0.0" left="30.0" /></padding>
                    <children>
                        <Label text="Admin Dashboard - Magazine Management" styleClass="admin-topbar-title"/>
                        <HBox spacing="10.0" styleClass="admin-tabs-container">
                            <padding><Insets top="20.0" /></padding>
                            <children>
                                <Button text="Gestion des Magazines" styleClass="admin-tab, admin-tab-active" onAction="#ouvrirPageMagazines" />
                                <Button text="Rédaction d'Articles" styleClass="admin-tab" onAction="#ouvrirPageArticles" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- MAIN CONTENT -->
                <VBox VBox.vgrow="ALWAYS" spacing="20.0">
                    <padding><Insets top="30.0" right="40.0" bottom="30.0" left="40.0" /></padding>
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label text="les magazine" styleClass="admin-page-title" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button onAction="#ajouterMagazine" styleClass="admin-add-btn" text="+ Ajouter un Magazine" />
                            </children>
                        </HBox>
                        
                        <VBox VBox.vgrow="ALWAYS" styleClass="admin-table-card">
                            <padding><Insets top="10.0" right="10.0" bottom="10.0" left="10.0" /></padding>
                            <children>
                                <TableView fx:id="tableMagazines" VBox.vgrow="ALWAYS" styleClass="admin-table">
                                    <columns>
                                        <TableColumn fx:id="colIdMag" prefWidth="60.0" text="ID" />
                                        <TableColumn fx:id="colTitreMag" prefWidth="250.0" text="Title" />
                                        <TableColumn fx:id="colDescriptionMag" prefWidth="300.0" text="Description" />
                                        <TableColumn fx:id="colStatutMag" prefWidth="100.0" text="Status" />
                                        <TableColumn fx:id="colDateCreateMag" prefWidth="120.0" text="Creation Date" />
                                        <TableColumn fx:id="colActionsMag" prefWidth="150.0" text="Actions" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>