<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import java.lang.String?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.pidev.controllers.FeedbackController"
      spacing="20" styleClass="content-area" stylesheets="@../styles/style.css">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox HBox.hgrow="ALWAYS">
            <Label text="⭐ Gestion des Feedbacks" styleClass="page-title"/>
            <Label text="Consulter et gérer les avis des patients" styleClass="page-subtitle"/>
        </VBox>
        <TextField fx:id="searchField" promptText="🔍 Rechercher..." styleClass="search-field" prefWidth="250"
                   onKeyReleased="#onSearch"/>
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- TABLE -->
        <VBox HBox.hgrow="ALWAYS" styleClass="card" spacing="12">
            <TableView fx:id="tableFeedbacks" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn text="ID" prefWidth="50">
                        <cellValueFactory><PropertyValueFactory property="id"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Patient" prefWidth="140">
                        <cellValueFactory><PropertyValueFactory property="patientName"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Médecin" prefWidth="140">
                        <cellValueFactory><PropertyValueFactory property="medecinName"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Note" prefWidth="60">
                        <cellValueFactory><PropertyValueFactory property="rating"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Commentaire" prefWidth="220">
                        <cellValueFactory><PropertyValueFactory property="comment"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Date" prefWidth="130">
                        <cellValueFactory><PropertyValueFactory property="createdAt"/></cellValueFactory>
                    </TableColumn>
                </columns>
            </TableView>
        </VBox>

        <!-- FORM -->
        <VBox styleClass="card" prefWidth="320" spacing="14">
            <Label text="📝 Formulaire Feedback" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #a78bfa;"/>
            <Separator/>

            <Label text="Patient" styleClass="form-label"/>
            <ComboBox fx:id="cbPatient" promptText="Sélectionner un patient" maxWidth="Infinity"/>

            <Label text="Médecin" styleClass="form-label"/>
            <ComboBox fx:id="cbDoctor" promptText="Sélectionner un médecin" maxWidth="Infinity"/>

            <Label text="Rendez-vous" styleClass="form-label"/>
            <ComboBox fx:id="cbAppointment" promptText="Sélectionner un RDV" maxWidth="Infinity"/>

            <Label text="Note (1-5)" styleClass="form-label"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <ComboBox fx:id="cbRating" promptText="Note" prefWidth="100">
                    <items>
                        <javafx.collections.FXCollections fx:factory="observableArrayList">
                            <String fx:value="1"/>
                            <String fx:value="2"/>
                            <String fx:value="3"/>
                            <String fx:value="4"/>
                            <String fx:value="5"/>
                        </javafx.collections.FXCollections>
                    </items>
                </ComboBox>
                <Label fx:id="lblStars" text="⭐⭐⭐⭐⭐" style="-fx-font-size: 18px;"/>
            </HBox>

            <Label text="Commentaire" styleClass="form-label"/>
            <TextArea fx:id="taComment" promptText="Écrire un commentaire..." prefRowCount="4"/>

            <Separator/>

            <HBox spacing="10" alignment="CENTER">
                <Button text="➕ Ajouter" styleClass="btn-primary" onAction="#addFeedback"/>
                <Button text="✏️ Modifier" styleClass="btn-warning" onAction="#updateFeedback"/>
                <Button text="🗑️ Supprimer" styleClass="btn-danger" onAction="#deleteFeedback"/>
            </HBox>
            <Button text="🔄 Réinitialiser" styleClass="btn-secondary" onAction="#clearForm" maxWidth="Infinity"/>
        </VBox>
    </HBox>
</VBox>
