<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>
<?import java.lang.String?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.pidev.controllers.RegisterController"
           stylesheets="@../styles/style.css"
           style="-fx-background-color: #080b14;">

    <VBox alignment="CENTER" maxWidth="520" spacing="0"
          style="-fx-background-color: #0e1220;
                 -fx-background-radius: 14;
                 -fx-border-color: #252d42;
                 -fx-border-width: 1;
                 -fx-border-radius: 14;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 30, 0, 0, 8);">

        <!-- Card header -->
        <VBox alignment="CENTER" spacing="8"
              style="-fx-background-color: #141826;
                     -fx-background-radius: 14 14 0 0;
                     -fx-border-color: transparent transparent #252d42 transparent;
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 28 40 22 40;">
            <StackPane alignment="CENTER">
                <Circle radius="26"
                        style="-fx-fill: rgba(91,110,245,0.15);
                               -fx-stroke: rgba(91,110,245,0.4);
                               -fx-stroke-width: 1;"/>
                <Label text="⚕" style="-fx-font-size: 22px; -fx-text-fill: #818cf8;"/>
            </StackPane>
            <Label text="Créer un compte"
                   style="-fx-font-size: 19px; -fx-font-weight: 700; -fx-text-fill: #f1f5f9;"/>
            <Label text="Sélectionnez votre rôle pour commencer"
                   style="-fx-font-size: 13px; -fx-text-fill: #94a3b8;"/>
        </VBox>

        <!-- Form body with ScrollPane -->
        <ScrollPane fitToWidth="true" 
                    maxHeight="500"
                    style="-fx-background-color: transparent; 
                           -fx-background: transparent;
                           -fx-border-color: transparent;">
            <VBox spacing="16" style="-fx-padding: 24 40 30 40;">

                <!-- Role selector -->
                <HBox alignment="CENTER" spacing="12">
                    <ToggleButton fx:id="btnPatient"
                                  text="Patient"
                                  selected="true"
                                  onAction="#handleRoleChanged"
                                  prefWidth="130" prefHeight="38"/>
                    <ToggleButton fx:id="btnMedecin"
                                  text="Médecin"
                                  onAction="#handleRoleChanged"
                                  prefWidth="130" prefHeight="38"/>
                </HBox>

                <GridPane hgap="14" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>

                    <VBox spacing="7" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Prénom" styleClass="form-label"/>
                        <TextField fx:id="firstNameField" promptText="Jean" styleClass="text-field"/>
                    </VBox>

                    <VBox spacing="7" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Nom" styleClass="form-label"/>
                        <TextField fx:id="lastNameField" promptText="Dupont" styleClass="text-field"/>
                    </VBox>

                    <VBox spacing="7" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                        <Label text="Adresse email" styleClass="form-label"/>
                        <TextField fx:id="emailField" promptText="nom@exemple.com" styleClass="text-field"/>
                    </VBox>

                    <VBox spacing="7" GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <Label text="Mot de passe" styleClass="form-label"/>
                        <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="password-field"/>
                    </VBox>

                    <VBox spacing="7" GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <Label text="Confirmer" styleClass="form-label"/>
                        <PasswordField fx:id="confirmPasswordField" promptText="••••••••" styleClass="password-field"/>
                    </VBox>

                    <VBox fx:id="extraFields" spacing="12"
                          GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2">
                        <VBox spacing="7">
                            <Label text="Téléphone" styleClass="form-label"/>
                            <TextField fx:id="phoneField" promptText="+216 XX XXX XXX" styleClass="text-field"/>
                        </VBox>
                        <VBox spacing="7">
                            <Label text="Date de naissance" styleClass="form-label"/>
                            <DatePicker fx:id="dobPicker" promptText="Sélectionner la date" 
                                        maxWidth="Infinity" styleClass="date-picker"/>
                        </VBox>
                        <VBox spacing="7">
                            <CheckBox fx:id="hasInsuranceCheckBox" text="J'ai une assurance médicale"
                                      style="-fx-text-fill: #f1f5f9; -fx-font-size: 13px;"/>
                        </VBox>
                        <VBox spacing="7">
                            <Label text="Numéro d'assurance" styleClass="form-label"/>
                            <TextField fx:id="insuranceNumberField" promptText="Numéro d'assurance (optionnel)" 
                                       styleClass="text-field"/>
                        </VBox>
                        <VBox fx:id="specialtyBox" spacing="12" managed="false" visible="false">
                            <VBox spacing="7">
                                <Label text="Spécialité" styleClass="form-label"/>
                                <ComboBox fx:id="specialtyCombo" promptText="Choisir une spécialité"
                                          maxWidth="Infinity" styleClass="combo-box"/>
                            </VBox>
                            <HBox spacing="14">
                                <VBox spacing="7" HBox.hgrow="ALWAYS">
                                    <Label text="Gouvernorat" styleClass="form-label"/>
                                    <ComboBox fx:id="governorateCombo" promptText="Choisir un gouvernorat"
                                              maxWidth="Infinity" styleClass="combo-box"/>
                                </VBox>
                                <VBox spacing="7" HBox.hgrow="ALWAYS">
                                    <Label text="Numéro CIN" styleClass="form-label"/>
                                    <TextField fx:id="cinField" promptText="Numéro de CIN" styleClass="text-field"/>
                                </VBox>
                            </HBox>
                            <HBox spacing="14">
                                <VBox spacing="7" HBox.hgrow="ALWAYS">
                                    <Label text="Genre" styleClass="form-label"/>
                                    <ComboBox fx:id="genderCombo" promptText="Choisir le genre"
                                              maxWidth="Infinity" styleClass="combo-box">
                                        <items>
                                            <javafx.collections.FXCollections fx:factory="observableArrayList">
                                                <String fx:value="Homme"/>
                                                <String fx:value="Femme"/>
                                            </javafx.collections.FXCollections>
                                        </items>
                                    </ComboBox>
                                </VBox>
                                <VBox spacing="7" HBox.hgrow="ALWAYS">
                                    <Label text="Âge" styleClass="form-label"/>
                                    <TextField fx:id="ageField" promptText="Votre âge" styleClass="text-field"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </VBox>
                </GridPane>

                <Label fx:id="errorMessage"
                       style="-fx-text-fill: #f43f5e; -fx-font-size: 12px; -fx-wrap-text: true; -fx-padding: 8 12; -fx-background-color: rgba(244,63,94,0.1); -fx-background-radius: 6; -fx-border-color: rgba(244,63,94,0.3); -fx-border-width: 1; -fx-border-radius: 6;"
                       visible="false"/>

                <Button fx:id="registerButton"
                        text="Créer mon compte"
                        onAction="#handleRegister"
                        maxWidth="Infinity"
                        prefHeight="42"
                        styleClass="btn-primary"
                        style="-fx-font-size: 14px;"/>

                <HBox alignment="CENTER" spacing="5">
                    <Label text="Déjà un compte ?" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>
                    <Hyperlink text="Connectez-vous" onAction="#showLogin"
                               style="-fx-text-fill: #818cf8; -fx-font-weight: 600;
                                      -fx-font-size: 13px; -fx-border-width: 0;"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </VBox>

</StackPane>
