<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml" 
      fx:controller="com.pidev.controllers.AppointmentBookingController"
      spacing="0" 
      style="-fx-background-color: #0e1220;"
      prefWidth="550" prefHeight="650">
    
    <!-- Scrollable Content -->
    <ScrollPane style="-fx-background-color: #0e1220; -fx-padding: 0; -fx-border-color: transparent;" 
                fitToWidth="true"
                VBox.vgrow="ALWAYS">
        <VBox spacing="20" 
              style="-fx-padding: 25; -fx-background-color: #0e1220;">
            
            <!-- Title -->
            <Label text="Prendre un Rendez-vous" 
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f1f5f9;"/>
            
            <!-- Doctor Info Card -->
            <VBox spacing="12" 
                  style="-fx-padding: 18; -fx-background-color: #141826; -fx-background-radius: 12; -fx-border-color: #252d42; -fx-border-width: 1; -fx-border-radius: 12;">
                <Label text="Médecin Sélectionné" 
                       style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #94a3b8;"/>
                <Label fx:id="doctorNameLabel" 
                       text="Dr. Name" 
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #f1f5f9;"/>
                <Label fx:id="doctorSpecialtyLabel" 
                       text="Specialty" 
                       style="-fx-font-size: 14px; -fx-text-fill: #22c55e;"/>
            </VBox>
            
            <!-- Date Selection -->
            <VBox spacing="10">
                <Label text="📅 Date du rendez-vous" 
                       style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #f1f5f9;"/>
                <DatePicker fx:id="appointmentDatePicker" 
                            prefWidth="Infinity"
                            style="-fx-font-size: 13px; -fx-padding: 10; -fx-background-color: #141826; -fx-text-fill: #f1f5f9; -fx-border-color: #252d42; -fx-border-width: 1; -fx-border-radius: 8;"/>
                <Label fx:id="dateErrorLabel" 
                       text="" 
                       style="-fx-text-fill: #ef4444; -fx-font-size: 12px;"/>
            </VBox>
            
            <!-- Time Selection -->
            <VBox spacing="10">
                <Label text="🕐 Heure du rendez-vous" 
                       style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #f1f5f9;"/>
                <ComboBox fx:id="appointmentTimeCombo" 
                          prefWidth="Infinity" 
                          promptText="Sélectionnez une heure"
                          style="-fx-font-size: 13px; -fx-padding: 10; -fx-background-color: #141826; -fx-text-fill: #f1f5f9; -fx-border-color: #252d42; -fx-border-width: 1; -fx-border-radius: 8;"/>
                <Label fx:id="timeErrorLabel" 
                       text="" 
                       style="-fx-text-fill: #ef4444; -fx-font-size: 12px;"/>
            </VBox>
            
            <!-- Notes -->
            <VBox spacing="10">
                <Label text="📝 Notes (Optionnel)" 
                       style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #f1f5f9;"/>
                <TextArea fx:id="notesArea" 
                          prefHeight="80" 
                          wrapText="true" 
                          promptText="Raison de la visite, symptômes, etc..."
                          style="-fx-font-size: 13px; -fx-padding: 10; -fx-background-color: #141826; -fx-text-fill: #f1f5f9; -fx-border-color: #252d42; -fx-border-width: 1; -fx-border-radius: 8; -fx-control-inner-background: #141826;"/>
            </VBox>
            
            <!-- Spacer -->
            <Region prefHeight="20"/>
        </VBox>
    </ScrollPane>
    
    <!-- Buttons (Fixed at Bottom) -->
    <HBox spacing="12" alignment="CENTER_RIGHT"
          style="-fx-padding: 20; -fx-background-color: #0e1220; -fx-border-color: #252d42; -fx-border-width: 1 0 0 0;">
        <Button text="Annuler" 
                onAction="#handleCancel" 
                style="-fx-padding: 12 30; -fx-font-size: 13px; -fx-font-weight: 600; -fx-background-color: #1e293b; -fx-text-fill: #f1f5f9; -fx-background-radius: 8; -fx-cursor: hand; -fx-border-color: #252d42; -fx-border-width: 1; -fx-border-radius: 8;"/>
        <Button text="✓ Confirmer" 
                onAction="#handleConfirm" 
                style="-fx-padding: 12 30; -fx-font-size: 13px; -fx-font-weight: 600; -fx-background-color: #22c55e; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-border-width: 0;"/>
    </HBox>
</VBox>
