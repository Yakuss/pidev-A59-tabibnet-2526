<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="800.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pidev.controllers.PatientCalendarViewController" style="-fx-background-color: transparent;">
    <children>
        <HBox AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0" spacing="0">
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;" HBox.hgrow="ALWAYS">
                <content>
                    <VBox spacing="20.0">
                        <padding>
                            <Insets top="30" right="20" bottom="24" left="30"/>
                        </padding>
        
                        <!-- Header Area -->
                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <Button onAction="#handleBack" styleClass="btn-secondary" text="⬅ Retour" />
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label fx:id="doctorNameTitle" text="Intelligence IA &amp; Planning" style="-fx-font-size: 26px; -fx-font-weight: 800; -fx-text-fill: #f1f5f9;"/>
                                <Label text="Optimisez votre emploi du temps grâce à l'analyse prédictive." style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;"/>
                            </VBox>
                            
                            <!-- Weather Summary Card -->
                            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #0e1220; -fx-padding: 10 20; -fx-background-radius: 12; -fx-border-color: #252d42; -fx-border-radius: 12;">
                                <Label text="🌍" style="-fx-font-size: 20px;"/>
                                <VBox alignment="CENTER_LEFT">
                                    <Label text="Prévisions" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                                    <Label fx:id="weatherStripLabel" text="Chargement..." style="-fx-text-fill: #818cf8; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                                </VBox>
                            </HBox>
                        </HBox>
        
                        <VBox spacing="20" style="-fx-background-color: #0e1220; -fx-background-radius: 12; -fx-border-color: #252d42; -fx-padding: 20;">
                            <!-- Navigation & AI Button -->
                            <HBox alignment="CENTER_LEFT" spacing="20">
                                <HBox spacing="10" alignment="CENTER">
                                    <Button onAction="#previousWeek" styleClass="btn-secondary" text="◀"/>
                                    <Label fx:id="weekLabel" text="Semaine du ..." style="-fx-font-size: 17px; -fx-font-weight: 700; -fx-text-fill: #f1f5f9; -fx-min-width: 250; -fx-alignment: center;" />
                                    <Button onAction="#nextWeek" styleClass="btn-secondary" text="▶"/>
                                </HBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button onAction="#fetchAiRecommendation" styleClass="btn-primary" text="✨ Recommander un créneau IA" style="-fx-background-color: #6366f1;"/>
                            </HBox>
                            <HBox fx:id="weekGrid" spacing="1" prefHeight="500" style="-fx-background-color: #252d42; -fx-background-radius: 12; -fx-border-color: #252d42; -fx-border-radius: 12; -fx-border-width: 1;"/>
                        </VBox>
        
                        <!-- AI Panel -->
                        <VBox fx:id="aiRecommendationPanel" visible="false" managed="false" spacing="12" style="-fx-background-color: rgba(99,102,241,0.1); -fx-border-color: #6366f1; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 20;">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label text="✨" style="-fx-font-size: 22px;"/>
                                <Label text="Analyse d'Intelligence Artificielle" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #f1f5f9;"/>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button text="✕" onAction="#hideAiPanel" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-cursor: hand; -fx-font-size: 16px;"/>
                            </HBox>
                            <Separator style="-fx-opacity: 0.1;"/>
                            <Label fx:id="aiStatusLabel" text="Analyse terminée" style="-fx-text-fill: #818cf8; -fx-font-size: 12px;"/>
                            <Label fx:id="aiRecommendationText" text="..." wrapText="true" style="-fx-text-fill: #f1f5f9; -fx-font-size: 14px;"/>
                            <HBox spacing="30">
                                <VBox spacing="4">
                                    <Label text="CRÉNEAU OPTIMAL" style="-fx-text-fill: #94a3b8; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                    <Label fx:id="aiBestSlotLabel" text="..." style="-fx-text-fill: #818cf8; -fx-font-weight: bold; -fx-font-size: 15px;"/>
                                </VBox>
                                <VBox spacing="4">
                                    <Label text="CONFIANCE" style="-fx-text-fill: #94a3b8; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                    <Label fx:id="aiAttendanceLabel" text="..." style="-fx-text-fill: #10b981; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- Sidebar -->
            <VBox prefWidth="240" spacing="20" style="-fx-background-color: #0e1220; -fx-border-color: transparent transparent transparent #252d42; -fx-border-width: 0 0 0 1;">
                <padding>
                    <Insets top="30" right="20" bottom="20" left="20"/>
                </padding>
                <Label text="AIDE AU PLANNING" style="-fx-font-weight: 900; -fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
                <VBox fx:id="patientHistoryPanel" spacing="10" VBox.vgrow="ALWAYS" />
                <VBox spacing="12" style="-fx-background-color: #1e293b; -fx-padding: 15; -fx-background-radius: 8;">
                    <Label text="LÉGENDE" style="-fx-font-weight: 800; -fx-font-size: 11px; -fx-text-fill: #f1f5f9;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Region style="-fx-background-color: #6366f1; -fx-min-width: 10; -fx-min-height: 10; -fx-background-radius: 3;"/>
                        <Label text="Planifié" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
                    </HBox>
                    <Separator style="-fx-opacity: 0.1;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="🎌" style="-fx-font-size: 14px;"/>
                        <Label text="Jour Férié" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="⚠" style="-fx-font-size: 14px; -fx-text-fill: #f43f5e;"/>
                        <Label text="Risque Météo" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
    </children>
</AnchorPane>
