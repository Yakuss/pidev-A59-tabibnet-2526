<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pidev.controllers.MedecinDirectoryController"
      stylesheets="@../styles/style.css"
      spacing="20"
      style="-fx-background-color: #080b14; -fx-padding: 24;">

    <!-- COMPACT HEADER WITH INLINE SEARCH -->
    <HBox alignment="CENTER_LEFT" spacing="24"
          style="-fx-background-color: #0e1220;
                 -fx-background-radius: 12;
                 -fx-border-color: #252d42;
                 -fx-border-width: 1;
                 -fx-border-radius: 12;
                 -fx-padding: 20 24;">

        <!-- Title Section -->
        <VBox spacing="2">
            <Label text="🩺 Annuaire des Médecins"
                   style="-fx-text-fill: #f1f5f9; -fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Label fx:id="resultsCount"
                   text="Chargement..."
                   style="-fx-text-fill: #22c55e; -fx-font-size: 13px; -fx-font-weight: 600;"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Compact Search Bar -->
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <TextField fx:id="searchName"
                      promptText="🔍 Rechercher un médecin..."
                      prefWidth="220"
                      style="-fx-background-color: #141826;
                             -fx-text-fill: #f1f5f9;
                             -fx-prompt-text-fill: #64748b;
                             -fx-border-color: #252d42;
                             -fx-border-width: 1;
                             -fx-border-radius: 20;
                             -fx-background-radius: 20;
                             -fx-padding: 8 16;
                             -fx-font-size: 13px;"/>

            <ComboBox fx:id="searchSpecialty"
                     promptText="Spécialité"
                     prefWidth="160"
                     style="-fx-background-color: #141826;
                            -fx-text-fill: #f1f5f9;
                            -fx-prompt-text-fill: #64748b;
                            -fx-border-color: #252d42;
                            -fx-border-width: 1;
                            -fx-border-radius: 8;
                            -fx-background-radius: 8;
                            -fx-padding: 6 12;
                            -fx-font-size: 13px;"/>

            <ComboBox fx:id="searchGovernorate"
                     promptText="Gouvernorat"
                     prefWidth="140"
                     style="-fx-background-color: #141826;
                            -fx-text-fill: #f1f5f9;
                            -fx-prompt-text-fill: #64748b;
                            -fx-border-color: #252d42;
                            -fx-border-width: 1;
                            -fx-border-radius: 8;
                            -fx-background-radius: 8;
                            -fx-padding: 6 12;
                            -fx-font-size: 13px;"/>

            <!-- Filter Toggle Button -->
            <Button fx:id="filterToggle" text="⚙️"
                    onAction="#toggleAdvancedFilters"
                    style="-fx-background-color: #22c55e;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-font-weight: 600;
                           -fx-padding: 8 12;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-border-width: 0;"/>
        </HBox>
    </HBox>

    <!-- COLLAPSIBLE ADVANCED FILTERS -->
    <VBox fx:id="advancedFiltersPanel" spacing="12" managed="false" visible="false"
          style="-fx-background-color: #0e1220;
                 -fx-background-radius: 12;
                 -fx-border-color: #252d42;
                 -fx-border-width: 1;
                 -fx-border-radius: 12;
                 -fx-padding: 16 20;">

        <Label text="🔧 Filtres avancés"
               style="-fx-text-fill: #f1f5f9; -fx-font-size: 15px; -fx-font-weight: 600;"/>

        <HBox spacing="20" alignment="CENTER_LEFT">
            <CheckBox fx:id="filterVerifiedOnly"
                     text="✓ Médecins vérifiés uniquement"
                     style="-fx-text-fill: #cbd5e1; -fx-font-size: 13px;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="🗑️ Effacer tous les filtres"
                    onAction="#clearFilters"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #64748b;
                           -fx-font-size: 12px;
                           -fx-font-weight: 600;
                           -fx-padding: 6 12;
                           -fx-background-radius: 6;
                           -fx-cursor: hand;
                           -fx-border-color: #252d42;
                           -fx-border-width: 1;
                           -fx-border-radius: 6;"/>
        </HBox>
    </VBox>

    <!-- HELPFUL HINT -->
    <HBox alignment="CENTER" spacing="8">
        <Label text="💡 Cliquez sur une carte pour voir le profil détaillé du médecin"
               style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-style: italic;"/>
    </HBox>

    <!-- MEDECINS LIST -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent;
                       -fx-background: transparent;">
        <ListView fx:id="listMedecins"
                 style="-fx-background-color: transparent;
                        -fx-background-insets: 0;
                        -fx-padding: 0;
                        -fx-border-width: 0;">
        </ListView>
    </ScrollPane>

</VBox>