                                <HBox alignment="CENTER_RIGHT" prefHeight="80.0" spacing="15.0" style="-fx-padding: 20 0 0 0; -fx-border-color: #e2e8f0 transparent transparent transparent; -fx-border-width: 2 0 0 0;">
