                                                <Font name="System Bold" size="11.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>

                                <Label fx:id="titleLabel" layoutX="40.0" layoutY="75.0" text="Détails du document" textFill="white">
                                    <font>
                                        <Font name="System Bold" size="32.0" />
                                    </font>
                                </Label>

                                <Label fx:id="subtitleLabel" layoutX="40.0" layoutY="115.0" text="Consultation de la pièce au dossier" textFill="rgba(255,255,255,0.8)">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                </Label>
                            </children>
                        </AnchorPane>

                        <VBox layoutY="180.0" prefWidth="700.0" spacing="35.0" style="-fx-padding: 40;">
                            <children>
                                <VBox spacing="20.0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="12.0">
