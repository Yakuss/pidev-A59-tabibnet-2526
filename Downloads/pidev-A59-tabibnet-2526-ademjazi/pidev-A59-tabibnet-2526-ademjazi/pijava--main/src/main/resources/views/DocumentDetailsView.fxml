                                                                <TextField fx:id="typeField" editable="false" prefHeight="48.0" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 0 15; -fx-font-size: 14;" />
