<ScrollPane fitToWidth="true" hbarPolicy="NEVER" maxHeight="-Infinity" prefHeight="650.0" prefWidth="800.0" style="-fx-background-color: #f8fafc;" vbarPolicy="AS_NEEDED" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pidev.controllers.DocumentDetailsController">
