                        <DropShadow color="#00000020" height="40.0" offsetY="10.0" radius="19.5" width="40.0" />
                    </effect>
                    <children>
                        <AnchorPane prefHeight="180.0" prefWidth="700.0" style="-fx-background-color: linear-gradient(to bottom right, #1d4ed8, #2563eb, #1e3a8a); -fx-background-radius: 24 24 0 0;">
                            <children>
                                <Circle fill="rgba(255,255,255,0.08)" layoutX="620.0" layoutY="-10.0" radius="140.0" />
