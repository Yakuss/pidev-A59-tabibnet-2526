                                <HBox alignment="CENTER_LEFT" layoutX="40.0" layoutY="30.0" spacing="8.0" style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 100; -fx-padding: 8 16; -fx-border-color: rgba(255,255,255,0.2); -fx-border-radius: 100; -fx-border-width: 1;">
