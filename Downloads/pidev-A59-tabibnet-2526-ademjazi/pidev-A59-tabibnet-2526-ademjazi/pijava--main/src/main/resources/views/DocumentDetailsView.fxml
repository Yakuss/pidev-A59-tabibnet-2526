                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <VBox spacing="20.0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                                            <children>
                                                <AnchorPane prefHeight="36.0" prefWidth="36.0" style="-fx-background-color: linear-gradient(to bottom right, #3b82f6, #1d4ed8); -fx-background-radius: 10;">
