<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pidev.controllers.ForumController"
            stylesheets="@../styles/style.css"
            style="-fx-background-color: #0a0e1a;">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- TOP HEADER -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <top>
        <VBox style="-fx-background-color: #0f1419; -fx-border-color: transparent transparent #1e2433 transparent; -fx-border-width: 0 0 1 0;">
            <!-- Main Header -->
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 20 32;">
                <!-- Icon + Title -->
                <HBox spacing="14" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <StackPane style="-fx-background-color: linear-gradient(135deg, #6366f1, #8b5cf6); -fx-background-radius: 14; -fx-padding: 14; -fx-effect: dropshadow(gaussian, rgba(99,102,241,0.5), 15, 0, 0, 4);">
                        <Label text="💬" style="-fx-font-size: 26px;"/>
                    </StackPane>
                    <VBox spacing="3">
                        <Label text="Forum Communautaire" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #f8fafc;"/>
                        <Label text="Partagez vos connaissances et résolvez les problèmes ensemble." style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>
                
                <!-- Search Field -->
                <TextField fx:id="searchField" promptText="🔍 Rechercher des questions..." prefWidth="320" prefHeight="42" style="-fx-background-color: #1a1f2e; -fx-text-fill: #f1f5f9; -fx-border-color: #2d3548; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 0 18; -fx-prompt-text-fill: #64748b; -fx-font-size: 14px;"/>
                
                <!-- Add Question Button -->
                <Button text="➕  Poser une question" onAction="#openAddDialog" prefHeight="42" style="-fx-background-color: linear-gradient(to right, #8b5cf6, #a855f7); -fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 14px; -fx-background-radius: 12; -fx-cursor: hand; -fx-padding: 0 24; -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.5), 12, 0, 0, 4);"/>
            </HBox>
            
            <!-- Status Bar -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: rgba(34,197,94,0.08); -fx-padding: 10 32; -fx-border-color: transparent transparent #1e2433 transparent; -fx-border-width: 0 0 1 0;">
                <Circle radius="4" style="-fx-fill: #22c55e;"/>
                <Label fx:id="lblStatus" text="Forum communautaire chargé" style="-fx-text-fill: #22c55e; -fx-font-size: 12px; -fx-font-weight: 700;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- CENTER CONTENT -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <center>
        <HBox spacing="0">
            
            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- LEFT SIDEBAR -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <VBox prefWidth="240" minWidth="240" spacing="0" style="-fx-background-color: #0f1419; -fx-border-color: transparent #1e2433 transparent transparent; -fx-border-width: 0 1 0 0;">
                
                <!-- Specialties Section -->
                <VBox spacing="4" style="-fx-padding: 20 16;">
                    <Label text="SPÉCIALITÉS" style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: 800; -fx-padding: 0 4 8 4; -fx-letter-spacing: 0.5;"/>
                    <VBox fx:id="specialitySidebar" spacing="3"/>
                </VBox>
                
                <Region VBox.vgrow="ALWAYS"/>
                
                <!-- Stats Section -->
                <VBox spacing="12" style="-fx-padding: 20 16; -fx-border-color: #1e2433 transparent transparent transparent; -fx-border-width: 1 0 0 0;">
                    <Label text="STATISTIQUES" style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: 800; -fx-padding: 0 4; -fx-letter-spacing: 0.5;"/>
                    
                    <!-- Questions Count -->
                    <VBox alignment="CENTER" spacing="6" style="-fx-background-color: rgba(99,102,241,0.12); -fx-background-radius: 12; -fx-padding: 16 12; -fx-border-color: rgba(99,102,241,0.2); -fx-border-radius: 12; -fx-border-width: 1;">
                        <Label fx:id="lblQuestionCount" text="6" style="-fx-text-fill: #818cf8; -fx-font-size: 28px; -fx-font-weight: 800;"/>
                        <Label text="Questions" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px; -fx-font-weight: 600;"/>
                    </VBox>
                    
                    <!-- Answers Count -->
                    <VBox alignment="CENTER" spacing="6" style="-fx-background-color: rgba(34,197,94,0.12); -fx-background-radius: 12; -fx-padding: 16 12; -fx-border-color: rgba(34,197,94,0.2); -fx-border-radius: 12; -fx-border-width: 1;">
                        <Label fx:id="lblAnswerCount" text="3" style="-fx-text-fill: #22c55e; -fx-font-size: 28px; -fx-font-weight: 800;"/>
                        <Label text="Réponses" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px; -fx-font-weight: 600;"/>
                    </VBox>
                </VBox>
            </VBox>

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- RIGHT CONTENT AREA -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <ScrollPane fx:id="scrollPane" fitToWidth="true" HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: #0a0e1a; -fx-border-color: transparent;">
                <padding>
                    <Insets top="24" right="32" bottom="24" left="32"/>
                </padding>
                <VBox fx:id="questionsContainer" spacing="16"/>
            </ScrollPane>
        </HBox>
    </center>

</BorderPane>
