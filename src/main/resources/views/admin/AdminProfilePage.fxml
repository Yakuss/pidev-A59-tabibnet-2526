<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pidev.controllers.AdminProfilePageController"
      spacing="25" style="-fx-padding: 30; -fx-background-color: white;">

    <HBox spacing="20" alignment="CENTER_LEFT">
        <StackPane style="-fx-background-color: #8b5cf6; -fx-background-radius: 60; -fx-padding: 15;">
            <Label text="🛡️" style="-fx-font-size: 42px; -fx-text-fill: white;"/>
        </StackPane>
        <VBox spacing="8">
            <Label fx:id="fullNameLabel" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="System Administrator" style="-fx-font-size: 16px; -fx-text-fill: #64748b;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="editButton" text="✏️  Edit Profile" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 24; -fx-background-radius: 10; -fx-cursor: hand;"
                onAction="#toggleEditMode"/>
    </HBox>

    <Separator style="-fx-background-color: #e2e8f0;"/>

    <!-- View Mode -->
    <VBox fx:id="viewModeContainer" spacing="20">
        <HBox spacing="15">
            <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: #f8fafc; -fx-padding: 20; -fx-background-radius: 16;">
                <Label text="📧 Email" style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                <Label fx:id="emailLabel" style="-fx-font-size: 14px; -fx-text-fill: #1e293b;" wrapText="true"/>
            </VBox>
            <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: #f8fafc; -fx-padding: 20; -fx-background-radius: 16;">
                <Label text="⚥ Gender" style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                <Label fx:id="genderLabel" style="-fx-font-size: 14px; -fx-text-fill: #1e293b;"/>
            </VBox>
        </HBox>
        <HBox spacing="15">
            <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: #f8fafc; -fx-padding: 20; -fx-background-radius: 16;">
                <Label text="🎂 Age" style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                <Label fx:id="ageLabel" style="-fx-font-size: 14px; -fx-text-fill: #1e293b;"/>
            </VBox>
            <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: #f8fafc; -fx-padding: 20; -fx-background-radius: 16;">
                <Label text="🏷️ Display Name" style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                <Label fx:id="displayNameLabel" style="-fx-font-size: 14px; -fx-text-fill: #1e293b;"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- Edit Mode -->
    <VBox fx:id="editModeContainer" spacing="20" visible="false" managed="false">
        <Label text="Edit Your Information" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

        <GridPane hgap="20" vgap="15">
            <Label text="First Name *" styleClass="profile-field" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="firstNameField" styleClass="text-field" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Last Name *" styleClass="profile-field" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="lastNameField" styleClass="text-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Age *" styleClass="profile-field" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="ageField" styleClass="text-field" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Gender *" styleClass="profile-field" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <ComboBox fx:id="genderCombo" styleClass="combo-box" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label text="Display Name *" styleClass="profile-field" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextField fx:id="displayNameField" styleClass="text-field" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            <Label text="New Password (optional)" styleClass="profile-field" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <PasswordField fx:id="passwordField" promptText="Leave blank to keep current" styleClass="password-field" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
        </GridPane>

        <Label fx:id="editErrorLabel" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px;" visible="false" wrapText="true"/>

        <HBox spacing="15">
            <Button text="💾  Save Changes" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 24; -fx-background-radius: 10; -fx-cursor: hand;"
                    onAction="#saveProfile"/>
            <Button text="❌  Cancel" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-font-weight: 600; -fx-padding: 12 24; -fx-background-radius: 10; -fx-cursor: hand;"
                    onAction="#toggleEditMode"/>
        </HBox>
    </VBox>

</VBox>