<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.pidev.controllers.LoginController"
           stylesheets="@../styles/style.css"
           style="-fx-background-color: linear-gradient(to bottom right, #f0f4f8, #d9e2ec);">

    <VBox alignment="CENTER" maxWidth="420" spacing="25" styleClass="card"
          style="-fx-background-color: white; -fx-padding: 40; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">

        <VBox alignment="CENTER" spacing="10">
            <Label text="⚕" style="-fx-font-size: 50px; -fx-text-fill: #3182ce;"/>
            <Label text="Welcome Back" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Sign in to your PiDev Medical account" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
        </VBox>

        <VBox spacing="15">
            <VBox spacing="8">
                <Label text="Email" styleClass="field-label"/>
                <TextField fx:id="emailField" promptText="your@email.com" styleClass="text-field"/>
            </VBox>
            <VBox spacing="8">
                <Label text="Password" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="password-field"/>
            </VBox>
            <HBox alignment="CENTER_RIGHT">
                <Hyperlink text="Forgot password?" style="-fx-text-fill: #3182ce; -fx-font-size: 12px;"/>
            </HBox>
        </VBox>

        <VBox spacing="15">
            <Button fx:id="loginButton" text="Sign In" onAction="#handleLogin"
                    maxWidth="Infinity" styleClass="primary-button" prefHeight="45"/>

            <HBox alignment="CENTER" spacing="5">
                <Label text="Don't have an account?" style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;"/>
                <Hyperlink text="Sign up" onAction="#goToRegister"
                           style="-fx-text-fill: #3182ce; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            </HBox>
        </VBox>

        <Label fx:id="errorLabel" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px;" visible="false"/>
    </VBox>
</StackPane>