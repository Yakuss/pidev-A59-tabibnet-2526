<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" style="-fx-padding: 20;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.RendezVousController">

    <Label text="Gestion des Rendez-vous"
           style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Rechercher:"/>
        <TextField fx:id="searchField"
                   promptText="Nom du patient..."
                   prefWidth="200"/>
        <Label fx:id="totalLabel" text="Total: 0" style="-fx-font-weight: bold;"/>
    </HBox>

    <GridPane hgap="10" vgap="8">
        <Label text="Nom patient:" GridPane.columnIndex="0"
               GridPane.rowIndex="0"/>
        <TextField fx:id="nomField"
                   promptText="ex: Ahmed Ben Ali"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="0" prefWidth="200"/>

        <Label text="Médecin:"
               GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <ComboBox fx:id="medecinCombo"
                  GridPane.columnIndex="1"
                  GridPane.rowIndex="1" prefWidth="200"/>

        <Label text="Date (dd/MM/yyyy):"
               GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="dateField"
                   promptText="ex: 15/06/2025"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="2"/>

        <Label text="Heure (HH:mm):"
               GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="heureField"
                   promptText="ex: 09:30"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="3"/>

        <Label text="Statut:"
               GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <ComboBox fx:id="statutCombo"
                  GridPane.columnIndex="1"
                  GridPane.rowIndex="4" prefWidth="200"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Ajouter"
                onAction="#handleAjouter"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
        <Button text="Modifier"
                onAction="#handleModifier"
                style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
        <Button text="Supprimer"
                onAction="#handleSupprimer"
                style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
        <Button text="Reset" onAction="#handleReset"/>
        <Button text="Voir Feedbacks →" onAction="#openFeedback"/>
    </HBox>

    <TableView fx:id="tableView" prefHeight="300">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colNom" text="Patient" prefWidth="110"/>
            <TableColumn fx:id="colMedecin" text="Médecin" prefWidth="120"/>
            <TableColumn fx:id="colDate" text="Date" prefWidth="80"/>
            <TableColumn fx:id="colHeure" text="Heure" prefWidth="60"/>
            <TableColumn fx:id="colStatut" text="Statut" prefWidth="80"/>
        </columns>
    </TableView>
</VBox>