<VBox spacing="10" style="-fx-padding: 20;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.FeedbackController">

    <Label text="Feedback"
           style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="8">
        <Label text="Rendez-vous:"
               GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <ComboBox fx:id="rdvCombo" prefWidth="200"
                  GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Note (1-5):"
               GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <ComboBox fx:id="noteCombo"
                  GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Commentaire:"
               GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextArea fx:id="commentaireArea" prefRowCount="3"
                  GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Ajouter feedback"
                onAction="#handleAjouter"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
        <Button text="Modifier"
                onAction="#handleModifier"
                style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
        <Button text="Supprimer"
                onAction="#handleSupprimer"
                style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
        <Button text="Reset" onAction="#handleReset"/>
    </HBox>

    <TableView fx:id="feedbackTable" prefHeight="250">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colRdvId" text="RDV#" prefWidth="60"/>
            <TableColumn fx:id="colNote" text="Note" prefWidth="60"/>
            <TableColumn fx:id="colCommentaire"
                         text="Commentaire" prefWidth="250"/>
        </columns>
    </TableView>
</VBox>