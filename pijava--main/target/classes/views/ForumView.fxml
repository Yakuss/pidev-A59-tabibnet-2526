<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pidev.controllers.ForumController"
      spacing="0"
      stylesheets="@../styles/style.css"
      style="-fx-background-color: #080b14;">

    <!-- HEADER -->
    <VBox style="-fx-background-color: #0e1220;
                 -fx-border-color: transparent transparent #252d42 transparent;
                 -fx-border-width: 0 0 1 0;
                 -fx-padding: 20 32 18 32;">
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Forum Communautaire"
                       style="-fx-font-size: 22px; -fx-font-weight: 700; -fx-text-fill: #f1f5f9;"/>
                <Label text="Partagez vos connaissances et résolvez les problèmes ensemble."
                       style="-fx-text-fill: #475569; -fx-font-size: 13px;"/>
            </VBox>
            <TextField fx:id="searchField"
                       promptText="Rechercher des questions…"
                       prefWidth="280" prefHeight="38"
                       styleClass="search-field"/>
            <Button text="+ Poser une question"
                    onAction="#openAddDialog"
                    prefHeight="38"
                    styleClass="btn-primary"/>
        </HBox>
    </VBox>

    <!-- MAIN CONTENT -->
    <HBox spacing="0" VBox.vgrow="ALWAYS">

        <!-- LEFT SIDEBAR -->
        <VBox prefWidth="220" minWidth="200" spacing="4"
              style="-fx-background-color: #0e1220;
                     -fx-border-color: transparent #252d42 transparent transparent;
                     -fx-border-width: 0 1 0 0;
                     -fx-padding: 18 10;">

            <Label text="SPÉCIALITÉS"
                   style="-fx-text-fill: #475569; -fx-font-size: 10px;
                          -fx-font-weight: 700; -fx-padding: 0 4 8 4;"/>

            <VBox fx:id="specialitySidebar" spacing="2"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator style="-fx-background-color: #252d42; -fx-max-height: 1;"/>
            <Region prefHeight="10"/>

            <Label text="STATISTIQUES"
                   style="-fx-text-fill: #475569; -fx-font-size: 10px;
                          -fx-font-weight: 700; -fx-padding: 0 4 8 4;"/>

            <HBox spacing="8" alignment="CENTER">
                <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: rgba(91,110,245,0.1);
                             -fx-background-radius: 10; -fx-padding: 14 8;">
                    <Label fx:id="lblQuestionCount" text="0"
                           style="-fx-text-fill: #818cf8; -fx-font-size: 22px; -fx-font-weight: 700;"/>
                    <Label text="Questions" style="-fx-text-fill: #475569; -fx-font-size: 11px;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: rgba(34,197,94,0.1);
                             -fx-background-radius: 10; -fx-padding: 14 8;">
                    <Label fx:id="lblAnswerCount" text="0"
                           style="-fx-text-fill: #22c55e; -fx-font-size: 22px; -fx-font-weight: 700;"/>
                    <Label text="Réponses" style="-fx-text-fill: #475569; -fx-font-size: 11px;"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- RIGHT CONTENT -->
        <VBox HBox.hgrow="ALWAYS" spacing="0" style="-fx-background-color: #080b14;">

            <!-- Status bar -->
            <HBox alignment="CENTER_LEFT" spacing="8"
                  style="-fx-background-color: #0e1220;
                         -fx-border-color: transparent transparent #252d42 transparent;
                         -fx-border-width: 0 0 1 0;
                         -fx-padding: 8 20;">
                <Circle radius="4" style="-fx-fill: #22c55e;"/>
                <Label fx:id="lblStatus" text="Prêt"
                       style="-fx-text-fill: #22c55e; -fx-font-size: 11px; -fx-font-weight: 600;"/>
            </HBox>

            <!-- Question cards -->
            <ScrollPane fx:id="scrollPane"
                        fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent;
                               -fx-border-color: transparent;
                               -fx-background: #080b14;">
                <padding>
                    <Insets top="20" right="28" bottom="20" left="28"/>
                </padding>
                <VBox fx:id="questionsContainer" spacing="12"/>
            </ScrollPane>
        </VBox>
    </HBox>

</VBox>
