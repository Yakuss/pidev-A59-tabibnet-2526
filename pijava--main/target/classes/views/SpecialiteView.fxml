<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.pidev.controllers.SpecialiteController"
            stylesheets="@../styles/specialite-modern.css"
            style="-fx-background-color: #0a0e1a;">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- TOP HEADER -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <top>
        <VBox style="-fx-background-color: #0f1419; -fx-border-color: transparent transparent #1e2433 transparent; -fx-border-width: 0 0 1 0;">
            <!-- Main Header -->
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 20 32;">
                <!-- Icon + Title -->
                <HBox spacing="14" alignment="CENTER_LEFT">
                    <StackPane style="-fx-background-color: linear-gradient(135deg, #6366f1, #8b5cf6); -fx-background-radius: 14; -fx-padding: 14; -fx-effect: dropshadow(gaussian, rgba(99,102,241,0.5), 15, 0, 0, 4);">
                        <Label text="🏥" style="-fx-font-size: 26px;"/>
                    </StackPane>
                    <VBox spacing="3">
                        <Label text="Gestion des Spécialités" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #f8fafc;"/>
                        <Label text="Ajouter, modifier ou supprimer les spécialités médicales" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>
                
                <Region HBox.hgrow="ALWAYS"/>
                
                <!-- Stats Badge -->
                <HBox spacing="10" alignment="CENTER" style="-fx-background-color: rgba(139,92,246,0.15); -fx-background-radius: 22; -fx-padding: 10 20; -fx-border-color: rgba(139,92,246,0.3); -fx-border-radius: 22; -fx-border-width: 1;">
                    <Label text="📊" style="-fx-font-size: 18px;"/>
                    <Label fx:id="lblCount" text="6 spécialité(s)" style="-fx-text-fill: #a78bfa; -fx-font-size: 14px; -fx-font-weight: 700;"/>
                </HBox>
                
                <!-- Search Field -->
                <TextField fx:id="searchField" promptText="🔍 Rechercher une spécialité..." prefWidth="320" prefHeight="42" style="-fx-background-color: #1a1f2e; -fx-text-fill: #f1f5f9; -fx-border-color: #2d3548; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 0 18; -fx-prompt-text-fill: #64748b; -fx-font-size: 14px;"/>
            </HBox>
            
            <!-- Status Bar -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: rgba(34,197,94,0.08); -fx-padding: 10 32; -fx-border-color: transparent transparent #1e2433 transparent; -fx-border-width: 0 0 1 0;">
                <Label text="✅" style="-fx-font-size: 13px;"/>
                <Label fx:id="lblStatus" text="Module Spécialités chargé" style="-fx-text-fill: #22c55e; -fx-font-size: 12px; -fx-font-weight: 700;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- CENTER CONTENT -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <center>
        <HBox spacing="24" style="-fx-padding: 24 32;">
            
            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- LEFT: TABLE SECTION -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <VBox HBox.hgrow="ALWAYS" spacing="0" style="-fx-background-color: #0f1419; -fx-background-radius: 16; -fx-border-color: #1e2433; -fx-border-width: 1; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 12, 0, 0, 3);">
                
                <!-- Table Header -->
                <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 20 24; -fx-background-color: #141921; -fx-background-radius: 16 16 0 0;">
                    <StackPane style="-fx-background-color: rgba(99,102,241,0.15); -fx-background-radius: 10; -fx-padding: 10;">
                        <Label text="📋" style="-fx-font-size: 20px;"/>
                    </StackPane>
                    <Label text="Liste des Spécialités" style="-fx-font-size: 17px; -fx-font-weight: 800; -fx-text-fill: #f8fafc;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Cliquez pour sélectionner" style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-style: italic;"/>
                </HBox>
                
                <Separator style="-fx-background-color: #1e2433; -fx-padding: 0;"/>

                <!-- Table -->
                <TableView fx:id="tableSpecialites" VBox.vgrow="ALWAYS" style="-fx-background-color: #0f1419; -fx-background-radius: 0 0 16 16; -fx-border-color: transparent; -fx-table-cell-border-color: #1e2433;">
                    <columns>
                        <TableColumn text="ID" prefWidth="70" style="-fx-alignment: CENTER;">
                            <cellValueFactory><PropertyValueFactory property="id"/></cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Nom de la Spécialité" prefWidth="300">
                            <cellValueFactory><PropertyValueFactory property="nom"/></cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Description" prefWidth="500">
                            <cellValueFactory><PropertyValueFactory property="description"/></cellValueFactory>
                        </TableColumn>
                    </columns>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="14" style="-fx-padding: 50;">
                            <Label text="📭" style="-fx-font-size: 56px; -fx-opacity: 0.4;"/>
                            <Label text="Aucune spécialité trouvée" style="-fx-text-fill: #94a3b8; -fx-font-size: 17px; -fx-font-weight: 700;"/>
                            <Label text="Ajoutez votre première spécialité médicale !" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                        </VBox>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- RIGHT: FORM SECTION -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <VBox prefWidth="380" spacing="0" style="-fx-background-color: #0f1419; -fx-background-radius: 16; -fx-border-color: #1e2433; -fx-border-width: 1; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 12, 0, 0, 3);">
                
                <!-- Form Header -->
                <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-padding: 20 24; -fx-background-color: #141921; -fx-background-radius: 16 16 0 0;">
                    <StackPane style="-fx-background-color: linear-gradient(135deg, #8b5cf6, #a855f7); -fx-background-radius: 12; -fx-padding: 12; -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.4), 10, 0, 0, 2);">
                        <Label text="✨" style="-fx-font-size: 22px;"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="Formulaire" style="-fx-font-size: 17px; -fx-font-weight: 800; -fx-text-fill: #f8fafc;"/>
                        <Label text="Remplir les champs ci-dessous" style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>
                    </VBox>
                </HBox>
                
                <Separator style="-fx-background-color: #1e2433;"/>

                <!-- Form Content -->
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <VBox spacing="18" style="-fx-padding: 24;">
                        
                        <!-- Nom de la spécialité Field -->
                        <VBox spacing="8">
                            <Label text="Nom de la spécialité" style="-fx-text-fill: #cbd5e1; -fx-font-weight: 700; -fx-font-size: 12px; -fx-letter-spacing: 0.5;"/>
                            <TextField fx:id="tfNom" promptText="ex: Cardiologie, Dermatologie..." style="-fx-background-color: #1a1f2e; -fx-text-fill: #f1f5f9; -fx-border-color: #2d3548; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12 16; -fx-prompt-text-fill: #64748b; -fx-font-size: 14px;"/>
                        </VBox>

                        <!-- Description Field -->
                        <VBox spacing="8">
                            <Label text="Description" style="-fx-text-fill: #cbd5e1; -fx-font-weight: 700; -fx-font-size: 12px; -fx-letter-spacing: 0.5;"/>
                            <TextArea fx:id="tfDescription" promptText="Décrivez cette spécialité médicale..." wrapText="true" prefRowCount="4" style="-fx-background-color: #1a1f2e; -fx-text-fill: #f1f5f9; -fx-border-color: #2d3548; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12 16; -fx-prompt-text-fill: #64748b; -fx-font-size: 14px; -fx-control-inner-background: #1a1f2e;"/>
                        </VBox>

                        <Separator style="-fx-background-color: #1e2433; -fx-padding: 8 0;"/>

                        <!-- Action Buttons -->
                        <VBox spacing="12">
                            <!-- Add Button -->
                            <Button fx:id="btnAdd" text="➕  Ajouter la spécialité" onAction="#addSpecialite" maxWidth="Infinity" prefHeight="46" style="-fx-background-color: linear-gradient(to right, #8b5cf6, #a855f7); -fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 14px; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.5), 12, 0, 0, 4);"/>

                            <!-- Modify Button -->
                            <Button fx:id="btnUpdate" text="📝  Modifier" onAction="#updateSpecialite" maxWidth="Infinity" prefHeight="44" style="-fx-background-color: linear-gradient(to right, #f59e0b, #f97316); -fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 14px; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(245,158,11,0.4), 10, 0, 0, 3);"/>

                            <!-- Delete Button -->
                            <Button fx:id="btnDelete" text="🗑️  Supprimer" onAction="#deleteSpecialite" maxWidth="Infinity" prefHeight="44" style="-fx-background-color: linear-gradient(to right, #dc2626, #ef4444); -fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 14px; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(220,38,38,0.4), 10, 0, 0, 3);"/>

                            <!-- Reset Button -->
                            <Button fx:id="btnClear" text="🔄  Réinitialiser" onAction="#clearForm" maxWidth="Infinity" prefHeight="40" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-border-color: #2d3548; -fx-border-radius: 12; -fx-background-radius: 12; -fx-cursor: hand; -fx-font-size: 13px; -fx-font-weight: 700;"/>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>
</BorderPane>
