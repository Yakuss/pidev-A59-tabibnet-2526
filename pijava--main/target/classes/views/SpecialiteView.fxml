<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.pidev.controllers.SpecialiteController"
      spacing="20" styleClass="content-area" stylesheets="@../styles/style.css">

    <!-- ═══════ HEADER SECTION ═══════ -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <Label text="🏥 Gestion des Spécialités" styleClass="page-title"/>
            <Label text="Ajouter, modifier ou supprimer les spécialités médicales" styleClass="page-subtitle"/>
        </VBox>
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Label fx:id="lblCount" text="0 spécialité(s)"
                   style="-fx-text-fill: #a78bfa; -fx-font-size: 13px; -fx-font-weight: bold;
                          -fx-background-color: rgba(167,139,250,0.1); -fx-padding: 6 16 6 16;
                          -fx-background-radius: 20;"/>
            <TextField fx:id="searchField" promptText="🔍 Rechercher une spécialité..." styleClass="search-field"
                       prefWidth="280"/>
        </HBox>
    </HBox>

    <!-- ═══════ STATUS BAR ═══════ -->
    <HBox style="-fx-background-color: #1a1d29; -fx-background-radius: 10; -fx-padding: 10 20 10 20;
                 -fx-border-color: #2d3040; -fx-border-radius: 10;" alignment="CENTER_LEFT" spacing="10">
        <Label text="📡" style="-fx-font-size: 14px;"/>
        <Label fx:id="lblStatus" text="✅ Prêt" style="-fx-text-fill: #10b981; -fx-font-size: 12px; -fx-font-weight: bold;"/>
    </HBox>

    <!-- ═══════ MAIN CONTENT AREA ═══════ -->
    <HBox spacing="20" VBox.vgrow="ALWAYS">

        <!-- ══ TABLE SECTION ══ -->
        <VBox HBox.hgrow="ALWAYS" styleClass="card" spacing="16">
            <!-- Table Header -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="📋 Liste des Spécialités"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #c4b5fd;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Cliquez pour sélectionner"
                       style="-fx-text-fill: #4b5563; -fx-font-size: 11px; -fx-font-style: italic;"/>
            </HBox>
            <Separator style="-fx-background-color: #2d3040;"/>

            <!-- Table -->
            <TableView fx:id="tableSpecialites" VBox.vgrow="ALWAYS"
                       style="-fx-min-height: 300;">
                <columns>
                    <TableColumn text="ID" prefWidth="70" style="-fx-alignment: CENTER;">
                        <cellValueFactory><PropertyValueFactory property="id"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Nom de la Spécialité" prefWidth="260">
                        <cellValueFactory><PropertyValueFactory property="nom"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Description" prefWidth="400">
                        <cellValueFactory><PropertyValueFactory property="description"/></cellValueFactory>
                    </TableColumn>
                </columns>
                <placeholder>
                    <Label text="Aucune spécialité trouvée. Ajoutez-en une !"
                           style="-fx-text-fill: #6b7280; -fx-font-style: italic; -fx-font-size: 14px;"/>
                </placeholder>
            </TableView>
        </VBox>

        <!-- ══ FORM SECTION ══ -->
        <VBox prefWidth="340" styleClass="card" spacing="16">
            <!-- Form Header -->
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="✨"
                       style="-fx-font-size: 20px; -fx-background-color: rgba(167,139,250,0.15);
                              -fx-padding: 8; -fx-background-radius: 8;"/>
                <VBox spacing="2">
                    <Label text="Formulaire"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #c4b5fd;"/>
                    <Label text="Remplir les champs ci-dessous"
                           style="-fx-text-fill: #4b5563; -fx-font-size: 11px;"/>
                </VBox>
            </HBox>
            <Separator style="-fx-background-color: #2d3040;"/>

            <!-- Nom Field -->
            <VBox spacing="6">
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="🏷️" style="-fx-font-size: 14px;"/>
                    <Label text="Nom de la spécialité" styleClass="form-label"
                           style="-fx-text-fill: #d1d5db; -fx-font-weight: bold;"/>
                    <Label text="*" style="-fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-font-size: 16px;"/>
                </HBox>
                <TextField fx:id="tfNom" promptText="ex: Cardiologie, Dermatologie..."
                           style="-fx-background-color: #252836; -fx-text-fill: #e4e6eb;
                                  -fx-border-color: #3d4059; -fx-border-radius: 10;
                                  -fx-background-radius: 10; -fx-padding: 12;
                                  -fx-prompt-text-fill: #6b7280; -fx-font-size: 14px;"/>
            </VBox>

            <!-- Description Field -->
            <VBox spacing="6">
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="📝" style="-fx-font-size: 14px;"/>
                    <Label text="Description" styleClass="form-label"
                           style="-fx-text-fill: #d1d5db; -fx-font-weight: bold;"/>
                </HBox>
                <TextField fx:id="tfDescription" promptText="Décrivez cette spécialité médicale..."
                           style="-fx-background-color: #252836; -fx-text-fill: #e4e6eb;
                                  -fx-border-color: #3d4059; -fx-border-radius: 10;
                                  -fx-background-radius: 10; -fx-padding: 12;
                                  -fx-prompt-text-fill: #6b7280; -fx-font-size: 14px;"
                           prefHeight="50"/>
            </VBox>

            <!-- Spacer -->
            <Region prefHeight="8"/>

            <!-- Action Buttons -->
            <Separator style="-fx-background-color: #2d3040;"/>

            <VBox spacing="10">
                <Button fx:id="btnAdd" text="➕  Ajouter la spécialité" onAction="#addSpecialite"
                        maxWidth="Infinity" prefHeight="42"
                        style="-fx-background-color: linear-gradient(to right, #6c5ce7, #a855f7);
                               -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;
                               -fx-background-radius: 10; -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, rgba(108,92,231,0.3), 8, 0, 0, 2);"/>

                <HBox spacing="10">
                    <Button fx:id="btnUpdate" text="✏️ Modifier" onAction="#updateSpecialite"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="38"
                            style="-fx-background-color: #f59e0b; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 10;
                                   -fx-cursor: hand; -fx-font-size: 13px;"/>
                    <Button fx:id="btnDelete" text="🗑️ Supprimer" onAction="#deleteSpecialite"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="38"
                            style="-fx-background-color: #dc2626; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 10;
                                   -fx-cursor: hand; -fx-font-size: 13px;"/>
                </HBox>

                <Button fx:id="btnClear" text="🔄  Réinitialiser le formulaire" onAction="#clearForm"
                        maxWidth="Infinity" prefHeight="36"
                        style="-fx-background-color: transparent; -fx-text-fill: #9ca3af;
                               -fx-border-color: #3d4059; -fx-border-radius: 10;
                               -fx-background-radius: 10; -fx-cursor: hand; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Help Section -->
            <Region VBox.vgrow="ALWAYS"/>
            <VBox spacing="6" style="-fx-background-color: rgba(108,92,231,0.06); -fx-padding: 14;
                                     -fx-background-radius: 10; -fx-border-color: rgba(108,92,231,0.15);
                                     -fx-border-radius: 10;">
                <Label text="💡 Aide rapide"
                       style="-fx-text-fill: #a78bfa; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <Label text="• Cliquez sur une ligne pour la modifier"
                       style="-fx-text-fill: #6b7280; -fx-font-size: 11px;" wrapText="true"/>
                <Label text="• Utilisez la barre de recherche pour filtrer"
                       style="-fx-text-fill: #6b7280; -fx-font-size: 11px;" wrapText="true"/>
                <Label text="• Le nom est obligatoire pour l'ajout"
                       style="-fx-text-fill: #6b7280; -fx-font-size: 11px;" wrapText="true"/>
            </VBox>
        </VBox>
    </HBox>
</VBox>
