<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.pidev.controllers.LoginController"
           stylesheets="@../styles/style.css"
           style="-fx-background-color: #080b14;">

    <VBox alignment="CENTER" maxWidth="420" spacing="0"
          style="-fx-background-color: #0e1220;
                 -fx-background-radius: 14;
                 -fx-border-color: #252d42;
                 -fx-border-width: 1;
                 -fx-border-radius: 14;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 30, 0, 0, 8);">

        <!-- Card header -->
        <VBox alignment="CENTER" spacing="10"
              style="-fx-background-color: #141826;
                     -fx-background-radius: 14 14 0 0;
                     -fx-border-color: transparent transparent #252d42 transparent;
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 36 40 28 40;">
            <StackPane alignment="CENTER">
                <Circle radius="28"
                        style="-fx-fill: rgba(91,110,245,0.15);
                               -fx-stroke: rgba(91,110,245,0.4);
                               -fx-stroke-width: 1;"/>
                <Label text="⚕" style="-fx-font-size: 26px; -fx-text-fill: #818cf8;"/>
            </StackPane>
            <Label text="PiDev Medical"
                   style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #f1f5f9;"/>
            <Label text="Connectez-vous à votre espace"
                   style="-fx-font-size: 13px; -fx-text-fill: #94a3b8;"/>
        </VBox>

        <!-- Form body -->
        <VBox spacing="18" style="-fx-padding: 28 40 32 40;">

            <VBox spacing="7">
                <Label text="Adresse email" styleClass="form-label"/>
                <TextField fx:id="emailField"
                           promptText="nom@exemple.com"
                           styleClass="text-field"/>
            </VBox>

            <VBox spacing="7">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Mot de passe" styleClass="form-label" HBox.hgrow="ALWAYS"/>
                    <Hyperlink text="Oublié ?" onAction="#showForgotPassword"
                               style="-fx-text-fill: #818cf8; -fx-font-size: 12px; -fx-border-width: 0;"/>
                </HBox>
                <PasswordField fx:id="passwordField"
                               promptText="••••••••"
                               styleClass="password-field"/>
            </VBox>

            <Label fx:id="errorMessage"
                   style="-fx-text-fill: #f43f5e; -fx-font-size: 12px; -fx-wrap-text: true; -fx-padding: 8 12; -fx-background-color: rgba(244,63,94,0.1); -fx-background-radius: 6; -fx-border-color: rgba(244,63,94,0.3); -fx-border-width: 1; -fx-border-radius: 6;"
                   visible="false"/>

            <Button fx:id="loginButton"
                    text="Se connecter"
                    onAction="#handleLogin"
                    maxWidth="Infinity"
                    prefHeight="42"
                    styleClass="btn-primary"
                    style="-fx-font-size: 14px;"/>

            <HBox alignment="CENTER" spacing="5">
                <Label text="Pas encore de compte ?"
                       style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>
                <Hyperlink text="Inscrivez-vous"
                           onAction="#showRegister"
                           style="-fx-text-fill: #818cf8; -fx-font-weight: 600;
                                  -fx-font-size: 13px; -fx-border-width: 0;"/>
            </HBox>
        </VBox>
    </VBox>

</StackPane>
