<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" style="-fx-padding: 20;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.PatientController">

    <!-- Section Réservation -->
    <VBox spacing="10" style="-fx-background-color: #f5f8fa; -fx-padding: 15; -fx-border-color: #ccc; -fx-border-radius: 5;">
        <Label text="Réserver une consultation" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #002D54;"/>
        <GridPane hgap="10" vgap="10">
            <Label text="Votre Nom : " GridPane.rowIndex="0" GridPane.columnIndex="0" />
            <TextField fx:id="nomPatientField" promptText="Ex: Ahmed Ben Ali" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200" />

            <Label text="Spécialiste :" GridPane.rowIndex="1" GridPane.columnIndex="0" />
            <ComboBox fx:id="medecinCombo" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="250" />
            
            <Label text="Date (dd/MM/yyyy) :" GridPane.rowIndex="2" GridPane.columnIndex="0" />
            <TextField fx:id="dateField" promptText="ex: 20/05/2026" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="200" />
            
            <Label text="Heure (HH:mm) :" GridPane.rowIndex="3" GridPane.columnIndex="0" />
            <TextField fx:id="heureField" promptText="ex: 10:30" GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="200" />
        </GridPane>
        <Button text="Confirmer le Rendez-vous" onAction="#handleReserver" style="-fx-background-color: #002D54; -fx-text-fill: white;" />
    </VBox>

    <Separator />

    <!-- Section Suivi et Avis -->
    <VBox spacing="10">
        <Label text="Suivre mes Rendez-vous et Laisser un Avis" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="searchNomField" promptText="Tapez votre nom..." prefWidth="250"/>
            <Button text="Chercher" onAction="#handleChercher" />
        </HBox>
        <TableView fx:id="patientTableView" prefHeight="150" prefWidth="760">
            <columns>
                <TableColumn fx:id="colDate" text="Date" prefWidth="100"/>
                <TableColumn fx:id="colHeure" text="Heure" prefWidth="80"/>
                <TableColumn fx:id="colMedecin" text="Médecin" prefWidth="250"/>
                <TableColumn fx:id="colStatut" text="Statut" prefWidth="120"/>
            </columns>
        </TableView>

        <HBox spacing="10" alignment="CENTER_LEFT" fx:id="annulerBox" visible="false">
            <Label text="Action sur ce rendez-vous :" style="-fx-text-fill: #555;"/>
            <Button text="❌ Annuler le Rendez-vous" onAction="#handleAnnulerRdv" style="-fx-background-color: #f44336; -fx-text-fill: white;" />
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT" fx:id="feedbackBox" visible="false">
            <Label text="Note (1 à 5):" />
            <ComboBox fx:id="noteCombo" />
            <TextField fx:id="commField" promptText="Laissez un commentaire..." prefWidth="300" />
            <Button text="Envoyer/Modifier l'Avis" onAction="#handleEnvoyerFeedback" style="-fx-background-color: #FF9800; -fx-text-fill: white;" />
        </HBox>
    </VBox>
</VBox>
