<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.pidev.controllers.ForgotPasswordController"
           stylesheets="@../styles/style.css"
           style="-fx-background-color: #080b14;">

    <VBox alignment="CENTER" maxWidth="460" spacing="0"
          style="-fx-background-color: #0e1220;
                 -fx-background-radius: 14;
                 -fx-border-color: #252d42;
                 -fx-border-width: 1;
                 -fx-border-radius: 14;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 30, 0, 0, 8);">

        <!-- Card header -->
        <VBox alignment="CENTER" spacing="8"
              style="-fx-background-color: #141826;
                     -fx-background-radius: 14 14 0 0;
                     -fx-border-color: transparent transparent #252d42 transparent;
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 28 40 22 40;">
            <StackPane alignment="CENTER">
                <Circle radius="26"
                        style="-fx-fill: rgba(91,110,245,0.15);
                               -fx-stroke: rgba(91,110,245,0.4);
                               -fx-stroke-width: 1;"/>
                <Label text="⚕" style="-fx-font-size: 22px; -fx-text-fill: #818cf8;"/>
            </StackPane>
            <Label text="PiDev Medical"
                   style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #f1f5f9;"/>
            <Label fx:id="lblStepTitle" text="Mot de passe oublié"
                   style="-fx-font-size: 13px; -fx-text-fill: #94a3b8;"/>

            <!-- Step indicator -->
            <HBox alignment="CENTER" spacing="8" style="-fx-padding: 8 0 0 0;">
                <Circle fx:id="dot1" radius="4" style="-fx-fill: #5b6ef5;"/>
                <Region style="-fx-background-color: #252d42; -fx-min-width: 30; -fx-max-height: 1;"/>
                <Circle fx:id="dot2" radius="4" style="-fx-fill: #252d42;"/>
                <Region style="-fx-background-color: #252d42; -fx-min-width: 30; -fx-max-height: 1;"/>
                <Circle fx:id="dot3" radius="4" style="-fx-fill: #252d42;"/>
            </HBox>
        </VBox>

        <!-- ── STEP 1: Enter email ── -->
        <VBox fx:id="stepEmail" spacing="16" style="-fx-padding: 28 40 32 40;">
            <Label text="Entrez votre adresse email et nous vous enverrons un code de vérification."
                   style="-fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-wrap-text: true;"/>

            <VBox spacing="7">
                <Label text="Adresse email" styleClass="form-label"/>
                <TextField fx:id="tfEmail"
                           promptText="votre@email.com"
                           styleClass="text-field"/>
            </VBox>

            <Label fx:id="lblEmailError"
                   style="-fx-text-fill: #f43f5e; -fx-font-size: 12px; -fx-wrap-text: true;"
                   visible="false" managed="false"/>

            <Button fx:id="btnSendCode"
                    text="Envoyer le code"
                    onAction="#handleSendCode"
                    maxWidth="Infinity" prefHeight="42"
                    styleClass="btn-primary"
                    style="-fx-font-size: 14px;"/>

            <HBox alignment="CENTER" spacing="5">
                <Label text="Retour à la connexion ?"
                       style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>
                <Hyperlink text="Se connecter" onAction="#goToLogin"
                           style="-fx-text-fill: #818cf8; -fx-font-weight: 600;
                                  -fx-font-size: 13px; -fx-border-width: 0;"/>
            </HBox>
        </VBox>

        <!-- ── STEP 2: Enter OTP ── -->
        <VBox fx:id="stepOTP" spacing="16" managed="false" visible="false"
              style="-fx-padding: 28 40 32 40;">

            <Label fx:id="lblOTPInfo" text="Un code a été envoyé à votre email."
                   style="-fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-wrap-text: true;"/>

            <VBox spacing="7">
                <Label text="Code de vérification (6 chiffres)" styleClass="form-label"/>
                <TextField fx:id="tfOTP"
                           promptText="_ _ _ _ _ _"
                           styleClass="text-field"
                           style="-fx-font-size: 22px; -fx-font-weight: 700;
                                  -fx-alignment: CENTER; -fx-letter-spacing: 8px;"/>
            </VBox>

            <Label fx:id="lblOTPError"
                   style="-fx-text-fill: #f43f5e; -fx-font-size: 12px; -fx-wrap-text: true;"
                   visible="false" managed="false"/>

            <Button text="Vérifier le code"
                    onAction="#handleVerifyOTP"
                    maxWidth="Infinity" prefHeight="42"
                    styleClass="btn-primary"
                    style="-fx-font-size: 14px;"/>

            <HBox alignment="CENTER" spacing="5">
                <Label text="Pas reçu ?"
                       style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>
                <Hyperlink text="Renvoyer le code" onAction="#handleSendCode"
                           style="-fx-text-fill: #818cf8; -fx-font-weight: 600;
                                  -fx-font-size: 13px; -fx-border-width: 0;"/>
            </HBox>
        </VBox>

        <!-- ── STEP 3: New password ── -->
        <VBox fx:id="stepNewPassword" spacing="16" managed="false" visible="false"
              style="-fx-padding: 28 40 32 40;">

            <Label text="Choisissez un nouveau mot de passe sécurisé (minimum 6 caractères)."
                   style="-fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-wrap-text: true;"/>

            <VBox spacing="7">
                <Label text="Nouveau mot de passe" styleClass="form-label"/>
                <PasswordField fx:id="tfNewPassword"
                               promptText="••••••••"
                               styleClass="password-field"/>
            </VBox>

            <VBox spacing="7">
                <Label text="Confirmer le mot de passe" styleClass="form-label"/>
                <PasswordField fx:id="tfConfirmPassword"
                               promptText="••••••••"
                               styleClass="password-field"/>
            </VBox>

            <Label fx:id="lblPasswordError"
                   style="-fx-text-fill: #f43f5e; -fx-font-size: 12px; -fx-wrap-text: true;"
                   visible="false" managed="false"/>

            <Button text="Réinitialiser le mot de passe"
                    onAction="#handleResetPassword"
                    maxWidth="Infinity" prefHeight="42"
                    styleClass="btn-primary"
                    style="-fx-font-size: 14px;"/>
        </VBox>

        <!-- ── STEP 4: Success ── -->
        <VBox fx:id="stepSuccess" spacing="20" alignment="CENTER" managed="false" visible="false"
              style="-fx-padding: 40 40 40 40;">
            <Label text="✓"
                   style="-fx-font-size: 48px; -fx-text-fill: #22c55e;"/>
            <Label text="Mot de passe réinitialisé !"
                   style="-fx-font-size: 17px; -fx-font-weight: 700; -fx-text-fill: #f1f5f9;"/>
            <Label text="Votre mot de passe a été mis à jour avec succès."
                   style="-fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-wrap-text: true;
                          -fx-text-alignment: CENTER;"/>
            <Button text="Se connecter"
                    onAction="#goToLogin"
                    maxWidth="Infinity" prefHeight="42"
                    styleClass="btn-primary"
                    style="-fx-font-size: 14px;"/>
        </VBox>

    </VBox>

</StackPane>
