<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml" 
      fx:controller="com.pidev.controllers.PatientAppointmentsController"
      spacing="0" 
      style="-fx-background-color: #0e1220;"
      VBox.vgrow="ALWAYS">
    
    <!-- Header -->
    <VBox spacing="20" 
          style="-fx-padding: 25; -fx-background-color: #0e1220; -fx-border-color: #252d42; -fx-border-width: 0 0 1 0;">
        <Label text="📅 Mes Rendez-vous" 
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #f1f5f9;"/>
        
        <!-- Filter and Sort Options -->
        <HBox spacing="15" alignment="CENTER_LEFT">
            <ComboBox fx:id="statusFilterCombo" 
                      prefWidth="200"
                      promptText="Filtrer par statut"
                      style="-fx-font-size: 13px; -fx-padding: 8; -fx-background-color: #141826; -fx-text-fill: #f1f5f9; -fx-border-color: #252d42; -fx-border-width: 1; -fx-border-radius: 6;"/>
            
            <Button text="🔄 Rafraîchir" 
                    onAction="#handleRefresh"
                    style="-fx-padding: 8 16; -fx-font-size: 13px; -fx-font-weight: 600; -fx-background-color: #22c55e; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand; -fx-border-width: 0;"/>
            
            <Region HBox.hgrow="ALWAYS"/>
            
            <Label fx:id="appointmentCountLabel" 
                   text="0 rendez-vous" 
                   style="-fx-font-size: 13px; -fx-text-fill: #94a3b8;"/>
        </HBox>
    </VBox>
    
    <!-- Appointments List -->
    <ScrollPane style="-fx-background-color: #0e1220; -fx-padding: 0;" 
                VBox.vgrow="ALWAYS"
                fitToWidth="true">
        <VBox fx:id="appointmentsContainer" 
              spacing="16" 
              style="-fx-padding: 25; -fx-background-color: #0e1220;">
            <!-- Appointments will be added here dynamically -->
        </VBox>
    </ScrollPane>
    
    <!-- Empty State -->
    <VBox fx:id="emptyStateBox" 
          spacing="16" 
          alignment="CENTER"
          style="-fx-padding: 60 25; -fx-background-color: #0e1220;"
          VBox.vgrow="ALWAYS">
        <Label text="📭" 
               style="-fx-font-size: 64px;"/>
        <Label text="Aucun rendez-vous" 
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #f1f5f9;"/>
        <Label text="Vous n'avez pas encore de rendez-vous. Consultez la liste des médecins pour en prendre un." 
               style="-fx-font-size: 13px; -fx-text-fill: #94a3b8; -fx-wrap-text: true;"
               maxWidth="400"/>
    </VBox>
</VBox>
